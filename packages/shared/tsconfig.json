{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "module": "CommonJS",
    "target": "ESNext",
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "strict": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/__smoke__/**", "src/**/__fixtures__/**", "src/ogmios/scripts/**"]
}
