# =============================================================================
# Phoenix Explorer — environment variable template
# Copy this file to packages/backend/.env for the backend, and copy
# packages/frontend/.env.example to packages/frontend/.env for the frontend.
# For the Docker Compose setup, copy this file to .env at the repo root.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend (packages/backend/.env)
# ---------------------------------------------------------------------------

# Blockfrost project API key — required when REACT_APP_API_TYPE=GATEWAY
# Obtain a key at https://blockfrost.io
# The key prefix must match the NETWORK value below (e.g. "mainnet..." for mainnet)
API_KEY=

# Port the Express backend server listens on (default: 3000)
PORT=3000

# Interface the backend binds to (default: 0.0.0.0 — all interfaces)
HOST=0.0.0.0

# Cardano network for Blockfrost: mainnet | preprod | preview
NETWORK=mainnet

# ---------------------------------------------------------------------------
# Frontend (packages/frontend/.env)
# ---------------------------------------------------------------------------

# Active data provider: GATEWAY | YACI | BLOCKFROST
# GATEWAY  — use the local Express backend (packages/backend) as a proxy to Blockfrost
# YACI     — connect directly to a Yaci Store REST API
# BLOCKFROST — connect directly to Blockfrost from the browser (exposes API key)
REACT_APP_API_TYPE=GATEWAY

# Base URL for the selected provider
# GATEWAY example:    http://localhost:3000/api
# YACI example:       http://localhost:8080/api/v1
# BLOCKFROST example: https://cardano-mainnet.blockfrost.io/api/v0
REACT_APP_API_URL=http://localhost:3000/api

# Display network name shown in the UI: mainnet | preprod | preview
REACT_APP_NETWORK=mainnet

# Blockfrost API key for browser-side direct calls (only used when REACT_APP_API_TYPE=BLOCKFROST)
# Warning: this value will be visible in the compiled JavaScript bundle
REACT_APP_BLOCKFROST_API_KEY=

# CoinGecko endpoint for ADA price data (leave as-is unless you are self-hosting)
REACT_APP_API_URL_COIN_GECKO=https://api.coingecko.com/api/v3/coins/markets

# Vite / CRA dev-server port (default: 3000 for CRA, 5173 for Vite)
PORT=5173
